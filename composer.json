{
    "name": "laboiteacode/filament-logs-explorer",
    "description": "Filament plugin to browse, read and search your Laravel log files, grouped by logging channel.",
    "keywords": [
        "laboiteacode",
        "laravel",
        "filament",
        "filamentphp",
        "logs",
        "log-viewer",
        "logging"
    ],
    "homepage": "https://github.com/la-boite-a-code/filament-logs-explorer",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexandre Ribes",
            "email": "alexandre@laboiteacode.fr",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "LaBoiteACode\\FilamentLogsExplorer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaBoiteACode\\FilamentLogsExplorer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaBoiteACode\\FilamentLogsExplorer\\FilamentLogsExplorerServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
